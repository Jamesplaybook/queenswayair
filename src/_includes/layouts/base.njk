<!DOCTYPE html>
<html lang="en-CA" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {# ── Titles & meta ─────────────────────────────────────────── #}
  {% set pageTitle = title + " | " + site.name if title else site.defaultTitle %}
  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ description if description else site.defaultDescription }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta name="robots" content="{{ robots if robots else 'follow, index, max-snippet:-1, max-image-preview:large' }}">

  {# ── Open Graph ────────────────────────────────────────────── #}
  <meta property="og:type"        content="{{ ogType if ogType else 'website' }}">
  <meta property="og:locale"      content="en_CA">
  <meta property="og:url"         content="{{ site.url }}{{ page.url }}">
  <meta property="og:title"       content="{{ pageTitle }}">
  <meta property="og:description" content="{{ description if description else site.defaultDescription }}">
  <meta property="og:image"       content="{{ site.url }}{{ ogImage if ogImage else site.ogImage }}">
  <meta property="og:site_name"   content="{{ site.name }}">

  {# ── Twitter Card ──────────────────────────────────────────── #}
  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:title"       content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ description if description else site.defaultDescription }}">
  <meta name="twitter:image"       content="{{ site.url }}{{ ogImage if ogImage else site.ogImage }}">

  {# ── Favicons ──────────────────────────────────────────────── #}
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" href="/assets/img/favicon/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/assets/img/favicon/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">

  {# ── Font preloads ─────────────────────────────────────────── #}
  <link rel="preload" href="/assets/fonts/poppins-400.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/poppins-600.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/poppins-700.woff2" as="font" type="font/woff2" crossorigin>

  {# ── Critical CSS inlined + full sheet linked ─────────────── #}
  <style>
    /* Critical above-the-fold styles */
    *,*::before,*::after{box-sizing:border-box}
    html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
    body{margin:0;font-family:"Poppins",system-ui,-apple-system,sans-serif;font-size:1rem;line-height:1.6;color:#434343;background:#fff;padding-bottom:60px}
    @media(min-width:992px){body{padding-bottom:0}}
    img,svg{display:block;max-width:100%}
    a{color:#E8392A;text-decoration:none}
    .site-top{position:sticky;top:0;z-index:100}
    .utility-bar{display:none;background:#1B2A6B;color:#fff;font-size:.875rem;padding:.5rem 0}
    @media(min-width:992px){.utility-bar{display:block}}
    .site-header{background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.08)}
    .site-header__inner{display:flex;align-items:center;justify-content:space-between;height:60px;gap:1rem}
    .site-logo{display:flex;align-items:center;gap:.75rem;flex-shrink:0;text-decoration:none;line-height:1.1}
    .site-logo__icon{height:44px;width:auto;flex-shrink:0}
    .site-logo__text{display:flex;flex-direction:column}
    .site-logo__brand{color:#E8392A;font-weight:700;font-size:1.1rem}
    .site-logo__sub{color:#1B2A6B;font-weight:600;font-size:.75rem;letter-spacing:.04em;text-transform:uppercase}
    .container{max-width:1140px;margin-inline:auto;padding-inline:clamp(1rem,4vw,2rem)}
  </style>
  <link rel="stylesheet" href="/assets/css/style.css">

  {# ── Structured data ───────────────────────────────────────── #}
  {% include "schema/local-business.njk" %}
  {% block schema %}{% endblock %}

  {# ── GTM (only if ID provided) ────────────────────────────── #}
  {% if site.gtmId %}
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','{{ site.gtmId }}');</script>
  {% endif %}
</head>

<body>
  {% if site.gtmId %}
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{ site.gtmId }}" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  {% endif %}

  <a href="#main-content" class="skip-link">Skip to main content</a>

  <div class="site-top">
    {% include "partials/top-utility-bar.njk" %}
    {% include "partials/header.njk" %}
  </div>

  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}
  {% include "partials/sticky-call-bar.njk" %}

  {# ── Meta Pixel (only if ID provided) ────────────────────── #}
  {% if site.metaPixelId %}
  <script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','{{ site.metaPixelId }}');fbq('track','PageView');</script>
  {% endif %}

  <script src="/assets/js/main.js" defer></script>
  <script src="/assets/js/form.js" defer></script>
</body>
</html>
