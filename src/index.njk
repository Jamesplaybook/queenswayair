---
layout: layouts/base.njk
title: "HVAC Repair, Furnace & AC Installation — Mississauga & GTA"
description: "Queensway Heating and Cooling — the GTA's trusted HVAC experts. Furnace repair, AC installation, heat pumps, ductless AC, fireplaces, and HRV services. Same-day emergency service. Call now."
---

{# ── HERO ────────────────────────────────────────────────────────────────── #}
<section class="hero" aria-label="Welcome">
  <div class="hero__bg" aria-hidden="true">
    {% heroImage "/assets/img/hero/hero-home.jpg", "Queensway technician servicing a furnace in a GTA home", "100vw" %}
  </div>
  <div class="hero__overlay" aria-hidden="true"></div>
  <div class="hero__content">
    <div class="container">
      <div class="hero__grid">
        <div class="hero__text">
          <h1>The GTA's Trusted Heating &amp; Cooling Experts</h1>
          <p class="hero__sub">Your comfort, guaranteed. Count on Queensway Heating and Cooling for furnace repair, AC installation, and heat pump services in Mississauga, Oakville, Brampton, and the GTA.</p>
          <div class="hero__ctas">
            <a href="tel:{{ site.phonePlain }}" class="btn btn-accent btn-lg" aria-label="Call {{ site.phone }}">
              {% icon "phone", "btn__icon", 20 %}
              Call: {{ site.phone }}
            </a>
            <a href="/quote/" class="btn btn-primary btn-lg">Get a Free Quote</a>
          </div>
        </div>
        {# Right column intentionally empty — breathing space on desktop #}
        <div aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

{# ── SERVICES INTRO HEADING ──────────────────────────────────────────────── #}
<div class="section-intro">
  <div class="container">
    <h2>Why You'll Love Our Expert Heating &amp; Cooling Services</h2>
    <p>From emergency furnace repair to heat pump installations with thousands in rebates — Queensway delivers honest, reliable HVAC service every time.</p>
  </div>
</div>

{# ── SERVICES GRID ───────────────────────────────────────────────────────── #}
<section class="section" style="padding-top:0" aria-label="Our services">
  <div class="container">
    <div class="service-grid">

      <a href="/services/furnace-installation/" class="service-card fade-in">
        <div class="service-card__icon" aria-hidden="true">
          {% icon "flame", "service-card__icon-svg", 40 %}
        </div>
        <div class="service-card__title">Furnace Installation</div>
        <p class="service-card__blurb">New high-efficiency gas furnace installed right the first time — with a warranty you can count on.</p>
      </a>

      <a href="/services/furnace-repair/" class="service-card fade-in">
        <div class="service-card__icon" aria-hidden="true">
          {% icon "wrench", "service-card__icon-svg", 40 %}
        </div>
        <div class="service-card__title">Furnace Repair</div>
        <p class="service-card__blurb">Fast furnace repair when you need it most — 24/7 emergency response across the GTA.</p>
      </a>

      <a href="/services/ac-installation/" class="service-card fade-in">
        <div class="service-card__icon" aria-hidden="true">
          {% icon "snowflake", "service-card__icon-svg", 40 %}
        </div>
        <div class="service-card__title">AC Installation</div>
        <p class="service-card__blurb">Cool your home efficiently with a new high-SEER central air conditioner — installed and guaranteed.</p>
      </a>

      <a href="/services/ac-repair/" class="service-card fade-in">
        <div class="service-card__icon" aria-hidden="true">
          {% icon "thermometer-snowflake", "service-card__icon-svg", 40 %}
        </div>
        <div class="service-card__title">AC Repair</div>
        <p class="service-card__blurb">AC not cooling? We diagnose and fix all brands — same-day appointments available.</p>
      </a>

      <a href="/services/heat-pump-installation/" class="service-card fade-in">
        <div class="service-card__icon" aria-hidden="true">
          {% icon "thermometer-sun", "service-card__icon-svg", 40 %}
        </div>
        <div class="service-card__title">Heat Pumps</div>
        <p class="service-card__blurb">Heating and cooling in one efficient system — up to $10,600 in government rebates available.</p>
      </a>

      <a href="/services/ductless-ac/" class="service-card fade-in">
        <div class="service-card__icon" aria-hidden="true">
          {% icon "air-vent", "service-card__icon-svg", 40 %}
        </div>
        <div class="service-card__title">Ductless AC</div>
        <p class="service-card__blurb">Mini-split systems for homes without ductwork — zoned comfort in any room, year-round.</p>
      </a>

      <a href="/services/water-heater/" class="service-card fade-in">
        <div class="service-card__icon" aria-hidden="true">
          {% icon "droplet", "service-card__icon-svg", 40 %}
        </div>
        <div class="service-card__title">Water Heaters</div>
        <p class="service-card__blurb">Tank and tankless water heaters — installed, repaired, and maintained by licensed gas technicians.</p>
      </a>

      <a href="/services/fireplaces/" class="service-card fade-in">
        <div class="service-card__icon" aria-hidden="true">
          {% icon "flame-kindling", "service-card__icon-svg", 40 %}
        </div>
        <div class="service-card__title">Fireplaces</div>
        <p class="service-card__blurb">Gas fireplace installation, service, and repair — add warmth and ambiance to any room.</p>
      </a>

      <a href="/services/hrv-erv/" class="service-card fade-in">
        <div class="service-card__icon" aria-hidden="true">
          {% icon "wind", "service-card__icon-svg", 40 %}
        </div>
        <div class="service-card__title">HRV &amp; ERV</div>
        <p class="service-card__blurb">Fresh air ventilation systems that recover heat — better indoor air quality, lower energy bills.</p>
      </a>

      <a href="/services/maintenance-plans/" class="service-card fade-in">
        <div class="service-card__icon" aria-hidden="true">
          {% icon "calendar-check", "service-card__icon-svg", 40 %}
        </div>
        <div class="service-card__title">Maintenance Plans</div>
        <p class="service-card__blurb">Annual tune-ups plus priority service and member savings — protect your HVAC investment.</p>
      </a>

      <a href="/financing/" class="service-card fade-in">
        <div class="service-card__icon" aria-hidden="true">
          {% icon "badge-dollar-sign", "service-card__icon-svg", 40 %}
        </div>
        <div class="service-card__title">Rebates &amp; Financing</div>
        <p class="service-card__blurb">Up to $10,600 in Ontario heat pump rebates. Flexible financing on all new equipment.</p>
      </a>

    </div>
  </div>
</section>

{# ── TRUST STRIP ("Why Choose Us") ──────────────────────────────────────── #}
<section class="trust-strip" aria-label="Why choose Queensway">
  <div class="container">
    <div class="trust-strip__grid">
      <div>
        <h2 class="trust-strip__heading">Why GTA Homeowners Choose Queensway</h2>
        <div class="trust-tiles">
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true">{% icon "users", "trust-tile__icon-svg" %}</div>
            <span class="trust-tile__text">{{ site.reviewCount }} 5-Star Reviews</span>
          </div>
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true">{% icon "clock", "trust-tile__icon-svg" %}</div>
            <span class="trust-tile__text">Same-Day Emergency Response</span>
          </div>
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true">{% icon "shield-check", "trust-tile__icon-svg" %}</div>
            <span class="trust-tile__text">Licensed &amp; Insured (TSSA)</span>
          </div>
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true">{% icon "credit-card", "trust-tile__icon-svg" %}</div>
            <span class="trust-tile__text">Flexible Financing Available</span>
          </div>
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true">{% icon "award", "trust-tile__icon-svg" %}</div>
            <span class="trust-tile__text">Certified Technicians</span>
          </div>
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true">{% icon "check", "trust-tile__icon-svg" %}</div>
            <span class="trust-tile__text">Quality Guarantee</span>
          </div>
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true">{% icon "dollar-sign", "trust-tile__icon-svg" %}</div>
            <span class="trust-tile__text">Transparent Flat-Rate Pricing</span>
          </div>
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true">{% icon "medal", "trust-tile__icon-svg" %}</div>
            <span class="trust-tile__text">{{ site.yearsInBusiness }}+ Years in Business</span>
          </div>
        </div>
      </div>
      <div class="trust-strip__image fade-in">
        {% image "/assets/img/sections/trust-tech-photo.jpg", "Queensway certified HVAC technician", "(min-width: 768px) 50vw, 100vw", [400,640,800,1200], "" %}
      </div>
    </div>
  </div>
</section>

{# ── QUOTE FORM + TESTIMONIAL BAND ───────────────────────────────────────── #}
<section class="quote-band" aria-label="Request a quote">
  <div class="quote-band__bg" aria-hidden="true">
    {% image "/assets/img/sections/quote-band-bg.jpg", "", "100vw" %}
  </div>
  <div class="quote-band__overlay" aria-hidden="true"></div>
  <div class="container">
    <div class="quote-band__grid">

      <div class="quote-band__form-wrap">
        {% include "partials/quote-form.njk" %}
      </div>

      <div>
        <h2 class="quote-band__title">Why Choose Us</h2>
        <ul class="quote-band__trust-list" role="list">
          <li class="quote-band__trust-item">
            {% icon "circle-check", "quote-band__trust-icon", 20 %}
            Same-day and emergency HVAC service available
          </li>
          <li class="quote-band__trust-item">
            {% icon "circle-check", "quote-band__trust-icon", 20 %}
            Transparent pricing — no hidden fees, ever
          </li>
          <li class="quote-band__trust-item">
            {% icon "circle-check", "quote-band__trust-icon", 20 %}
            TSSA licensed &amp; fully insured technicians
          </li>
          <li class="quote-band__trust-item">
            {% icon "circle-check", "quote-band__trust-icon", 20 %}
            We help you claim Ontario and federal rebates
          </li>
          <li class="quote-band__trust-item">
            {% icon "circle-check", "quote-band__trust-icon", 20 %}
            All work backed by our satisfaction guarantee
          </li>
        </ul>

        <hr style="border:none;border-top:1px solid rgba(255,255,255,0.2);margin:1.5rem 0;">

        <div class="quote-band__testimonial">
          <div class="stars-img" aria-label="5 stars" role="img">
            {% set starSize = 18 %}{% for i in range(0, 5) %}{% include "partials/star.njk" %}{% endfor %}
          </div>
          <blockquote>"My furnace stopped working on the coldest day of the year. Queensway had a technician at my door within 2 hours. Incredible service — I won't call anyone else."</blockquote>
          <cite>Sarah M. — <a href="/service-areas/mississauga/" style="color:rgba(255,255,255,0.7)">Mississauga</a></cite>
        </div>
      </div>

    </div>
  </div>
</section>

{# ── TESTIMONIALS ────────────────────────────────────────────────────────── #}
<section class="section" aria-label="Customer testimonials">
  <div class="container">
    <h2 class="text-center" style="margin-bottom:2rem;">What Our Customers Say</h2>
    <div class="testimonials__grid">
      {% for review in reviews | slice(0, 2) %}
      <article class="testimonial-card fade-in">
        <blockquote class="testimonial-card__quote">"{{ review.text }}"</blockquote>
        <footer class="testimonial-card__footer">
          <div class="testimonial-card__stars" aria-label="{{ review.rating }} stars" role="img">
            {% for i in range(0, review.rating) %}{% include "partials/star.njk" %}{% endfor %}
          </div>
          <span class="testimonial-card__name">{{ review.name }}</span>
          <span class="testimonial-card__city">
            {% if review.citySlug %}
            <a href="/service-areas/{{ review.citySlug }}/">{{ review.city }}</a>
            {% else %}
            {{ review.city }}
            {% endif %}
          </span>
        </footer>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

{# ── REVIEW PLATFORMS STRIP ──────────────────────────────────────────────── #}
<div class="review-platforms">
  <div class="container">
    <div class="review-platforms__grid">
      <div class="review-platform">
        <img src="/assets/img/brand-marks/homestars.svg" alt="HomeStars" width="140" height="52" loading="lazy">
        <p>Read our customer reviews on HomeStars</p>
        <a href="{{ site.homestarsUrl }}" target="_blank" rel="noopener noreferrer">Read Reviews →</a>
      </div>
      <div class="review-platform">
        <img src="/assets/img/brand-marks/google-reviews.svg" alt="Google Reviews" width="140" height="52" loading="lazy">
        <p>{{ site.reviewCount }} reviews on Google</p>
        <a href="{{ site.gbpUrl }}" target="_blank" rel="noopener noreferrer">Read Reviews →</a>
      </div>
    </div>
  </div>
</div>

{# ── FAQ ─────────────────────────────────────────────────────────────────── #}
<section class="faq-section" aria-label="Frequently asked questions">
  <div class="faq-section__bg" aria-hidden="true">
    {% image "/assets/img/sections/faq-bg.jpg", "", "100vw" %}
  </div>
  <div class="faq-section__overlay" aria-hidden="true"></div>
  <div class="container">
    <div class="faq-section__content">
      <div aria-hidden="true"></div>{# Left col — image shows through #}
      <div class="faq-section__questions">
        <h2>Frequently Asked Questions</h2>
        {% set faqItems = faqs %}
        {% include "partials/faq.njk" %}
        <p style="margin-top:1.5rem;"><a href="/contact/" class="btn btn-outline-white">Ask Your Question →</a></p>
      </div>
    </div>
  </div>
</section>

{# ── REGIONS WE SERVE ────────────────────────────────────────────────────── #}
<section class="regions" aria-label="Service areas">
  <div class="container">
    <h2>Regions We Serve</h2>
    <div class="regions__grid" role="list">
      {% for region in regions %}
      <div class="regions__city" role="listitem">
        {% if region.slug %}
        <a href="/service-areas/{{ region.slug }}/">{{ region.name }}</a>
        {% else %}
        {{ region.name }}
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ── CTA BAND ────────────────────────────────────────────────────────────── #}
{% include "partials/cta-band.njk" %}

{# ── FAQ SCHEMA ──────────────────────────────────────────────────────────── #}
{% block schema %}
{% set faqItems = faqs %}
{% include "schema/faq.njk" %}
{% endblock %}
