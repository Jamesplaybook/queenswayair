<form
  class="form"
  name="quote"
  method="POST"
  action="/api/lead"
  data-form="quote"
  novalidate
>
  <input type="hidden" name="form-name" value="quote">
  <p class="form__honeypot" aria-hidden="true"><label>Leave this blank: <input name="bot-field" tabindex="-1" autocomplete="off"></label></p>

  <h3 class="form__title">Get a Free Quote</h3>

  <div class="form__row form__row--half">
    <div>
      <label class="form__label" for="q-name">Name <span class="req">*</span></label>
      <input class="form__input" type="text" id="q-name" name="name" required autocomplete="name" placeholder="Jane Smith">
      <span class="form__error-msg" data-error="name"></span>
    </div>
    <div>
      <label class="form__label" for="q-phone">Phone <span class="req">*</span></label>
      <input class="form__input" type="tel" id="q-phone" name="phone" required autocomplete="tel" inputmode="numeric" placeholder="(905) 555-0100">
      <span class="form__error-msg" data-error="phone"></span>
    </div>
  </div>

  <div class="form__row form__row--half">
    <div>
      <label class="form__label" for="q-email">Email</label>
      <input class="form__input" type="email" id="q-email" name="email" autocomplete="email" placeholder="jane@example.com">
    </div>
    <div>
      <label class="form__label" for="q-postal">Postal Code</label>
      <input class="form__input" type="text" id="q-postal" name="postal" autocomplete="postal-code" placeholder="L5B 2X9">
    </div>
  </div>

  <fieldset style="border:none;padding:0;margin:0;">
    <legend class="form__label">I need help with <span class="req">*</span></legend>
    <div class="form__radio-group" style="margin-top:0.5rem;">
      <label class="form__radio-label"><input type="radio" name="service" value="Repair" required> Repair</label>
      <label class="form__radio-label"><input type="radio" name="service" value="New Equipment"> New Equipment</label>
      <label class="form__radio-label"><input type="radio" name="service" value="Maintenance"> Maintenance</label>
      <label class="form__radio-label"><input type="radio" name="service" value="Ask a Question"> Ask a Question</label>
    </div>
    <span class="form__error-msg" data-error="service"></span>
  </fieldset>

  <div>
    <label class="form__label" for="q-callback">Best time to call back</label>
    <select class="form__select" id="q-callback" name="callback">
      <option value="ASAP">As soon as possible</option>
      <option value="Morning">Mornings (8am–12pm)</option>
      <option value="Afternoon">Afternoons (12pm–5pm)</option>
      <option value="Evening">Evenings (after 5pm)</option>
    </select>
  </div>

  <div>
    <label class="form__label" for="q-message">How can we help?</label>
    <textarea class="form__textarea" id="q-message" name="message" rows="4" placeholder="Briefly describe your issue or what you need…"></textarea>
  </div>

  <div>
    <label class="form__label" for="q-source">How did you hear about us?</label>
    <select class="form__select" id="q-source" name="source">
      <option value="">— Select one —</option>
      <option>Google / Website</option>
      <option>Google Maps</option>
      <option>ChatGPT</option>
      <option>Other AI (Gemini, Perplexity, etc.)</option>
      <option>Social Media</option>
      <option>Online Ad</option>
      <option>Referral / Friend</option>
      <option>Saw Truck / Van</option>
      <option>Current Customer</option>
      <option>Other</option>
    </select>
  </div>

  <div class="form__submit">
    <button type="submit" class="btn btn-primary btn-lg">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      Send Request
    </button>
  </div>

  <div class="form__success" role="alert" aria-live="polite">
    <p><strong>Thank you!</strong> We've received your request and will be in touch shortly. For urgent issues call <a href="tel:{{ site.phonePlain }}">{{ site.phone }}</a>.</p>
  </div>
</form>
