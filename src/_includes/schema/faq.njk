<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in faqItems %}
    {
      "@type": "Question",
      "name": {{ item.q | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ item.a | json }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
