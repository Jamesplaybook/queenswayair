          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg></div>
            <span class="trust-tile__text">Certified Technicians</span>
          </div>
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg></div>
            <span class="trust-tile__text">Quality Guarantee</span>
          </div>
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg></div>
            <span class="trust-tile__text">Transparent Flat-Rate Pricing</span>
          </div>
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg></div>
            <span class="trust-tile__text">{{ site.yearsInBusiness }}+ Years in Business</span>
          </div>
        </div>
      </div>
      <div class="trust-strip__image fade-in">
        <img
          src="/assets/img/trust-photo.jpg"
          alt="Queensway Heating and Cooling certified HVAC technician"
          width="640" height="480"
          loading="lazy"
          decoding="async"
        >
      </div>
    </div>
