<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">

      {# Widget 1: Logo + social + copyright #}
      <div class="footer-widget">
        <a href="/" aria-label="{{ site.name }} — Home">
          <div class="footer-widget__logo">
            <img src="/assets/img/logos/logo-wordmark.svg" alt="{{ site.name }}" width="160" height="52">
          </div>
        </a>
        <div class="footer-social" aria-label="Social media links">
          {% if site.social.facebook %}
          <a href="{{ site.social.facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          {% endif %}
          {% if site.social.instagram %}
          <a href="{{ site.social.instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          {% endif %}
          {% if site.social.linkedin %}
          <a href="{{ site.social.linkedin }}" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          {% endif %}
        </div>
        <p class="footer-widget__copyright">
          &copy; {% year %} {{ site.name }}<br>
          <a href="/privacy/">Privacy Policy</a>
        </p>
      </div>

      {# Widget 2: Quick Links #}
      <div class="footer-widget">
        <h3 class="footer-widget__title">Quick Links</h3>
        <nav class="footer-nav" aria-label="Footer quick links">
          <a href="/">Home</a>
          <a href="/about/">About Us</a>
          <a href="/reviews/">Customer Reviews</a>
          <a href="/financing/">Rebates &amp; Financing</a>
          <a href="/service-areas/">Service Areas</a>
          <a href="/blog/">Blog</a>
          <a href="/quote/">Get a Free Quote</a>
          <a href="/contact/">Contact Us</a>
        </nav>
      </div>

      {# Widget 3: Services #}
      <div class="footer-widget">
        <h3 class="footer-widget__title">Our Services</h3>
        <nav class="footer-nav" aria-label="Footer services">
          {% for service in services %}
          <a href="/services/{{ service.slug }}/">{{ service.title }}</a>
          {% endfor %}
        </nav>
      </div>

      {# Widget 4: Location #}
      <div class="footer-widget">
        <h3 class="footer-widget__title">Our Location</h3>
        <div class="footer-location">
          <address style="font-style:normal">
            <a href="{{ site.address.mapUrl }}" target="_blank" rel="noopener noreferrer">
              {{ site.address.street }}<br>
              {{ site.address.city }}, {{ site.address.province }} {{ site.address.postal }}
            </a>
          </address>
          <a href="tel:{{ site.phonePlain }}" class="footer-location__phone">{{ site.phone }}</a>
          <a href="mailto:{{ site.email }}">{{ site.email }}</a>
          <p style="color:rgba(255,255,255,0.65); font-size:0.8rem; margin-top:0.5rem;">{{ site.hours }}</p>
          {% if site.tssaLicense %}
          <p class="footer-tssa">TSSA Lic. {{ site.tssaLicense }}</p>
          {% endif %}
        </div>
        {% if site.certs.length %}
        <div class="credential-badges" aria-label="Certifications and awards">
          {% for cert in site.certs %}
          <img src="{{ cert.logo }}" alt="{{ cert.name }}" width="60" height="40">
          {% endfor %}
        </div>
        {% endif %}
      </div>

    </div>

    <div class="site-footer__bottom">
      <span>Licensed &amp; insured HVAC contractor serving Mississauga and the GTA</span>
      <span>
        <a href="/privacy/">Privacy Policy</a> &middot;
        <a href="/sitemap.xml">Sitemap</a>
      </span>
    </div>
  </div>
</footer>
