{# ── QUOTE FORM + TESTIMONIAL BAND ───────────────────────────────────────── #}
<section class="quote-band" aria-label="Request a quote">
  <div class="quote-band__bg" aria-hidden="true">
    <img src="/assets/img/quote-band-bg.jpg" alt="" width="1920" height="960" loading="lazy" decoding="async">
  </div>
  <div class="quote-band__overlay" aria-hidden="true"></div>
  <div class="container">
    <div class="quote-band__grid">

      <div class="quote-band__form-wrap">
        {% include "partials/quote-form.njk" %}
      </div>

      <div>
        <h2 class="quote-band__title">Why Choose Us</h2>
        <ul class="quote-band__trust-list" role="list">
          <li class="quote-band__trust-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Same-day and emergency HVAC service available
          </li>
          <li class="quote-band__trust-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Transparent pricing — no hidden fees, ever
          </li>
          <li class="quote-band__trust-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            TSSA licensed &amp; fully insured technicians
          </li>
          <li class="quote-band__trust-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            We help you claim Ontario and federal rebates
          </li>
          <li class="quote-band__trust-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            All work backed by our satisfaction guarantee
          </li>
        </ul>

        <hr style="border:none;border-top:1px solid rgba(255,255,255,0.2);margin:1.5rem 0;">

        <div class="quote-band__testimonial">
          <div class="stars-img" aria-label="5 stars" role="img">
            {% for i in range(0, 5) %}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {% endfor %}
          </div>
          <blockquote>"My furnace stopped working on the coldest day of the year. Queensway had a technician at my door within 2 hours. Incredible service — I won't call anyone else."</blockquote>
          <cite>Sarah M. — <a href="/service-areas/mississauga/" style="color:rgba(255,255,255,0.7)">Mississauga</a></cite>
        </div>
      </div>

    </div>
  </div>
</section>

{# ── TESTIMONIALS ────────────────────────────────────────────────────────── #}
<section class="section" aria-label="Customer testimonials">
  <div class="container">
    <h2 class="text-center" style="margin-bottom:2rem;">What Our Customers Say</h2>
    <div class="testimonials__grid">
      {% for review in reviews | slice(0, 2) %}
      <article class="testimonial-card fade-in">
        <blockquote class="testimonial-card__quote">"{{ review.text }}"</blockquote>
        <footer class="testimonial-card__footer">
          <div class="testimonial-card__stars" aria-label="{{ review.rating }} stars" role="img">
            {% for i in range(0, review.rating) %}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {% endfor %}
          </div>
          <span class="testimonial-card__name">{{ review.name }}</span>
          <span class="testimonial-card__city">
            {% if review.citySlug %}
            <a href="/service-areas/{{ review.citySlug }}/">{{ review.city }}</a>
            {% else %}
            {{ review.city }}
            {% endif %}
          </span>
        </footer>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

{# ── REVIEW PLATFORMS STRIP ──────────────────────────────────────────────── #}
<div class="review-platforms">
  <div class="container">
    <div class="review-platforms__grid">
      <div class="review-platform">
        <img src="/assets/img/homestars-logo.png" alt="HomeStars" width="140" height="52" loading="lazy">
        <p>Read our customer reviews on HomeStars</p>
        <a href="{{ site.homestarsUrl }}" target="_blank" rel="noopener noreferrer">Read Reviews →</a>
      </div>
      <div class="review-platform">
        <img src="/assets/img/google-reviews-logo.png" alt="Google Reviews" width="140" height="52" loading="lazy">
        <p>{{ site.reviewCount }} reviews on Google</p>
        <a href="{{ site.gbpUrl }}" target="_blank" rel="noopener noreferrer">Read Reviews →</a>
      </div>
    </div>
  </div>
</div>

{# ── FAQ ─────────────────────────────────────────────────────────────────── #}
<section class="faq-section" aria-label="Frequently asked questions">
  <div class="faq-section__bg" aria-hidden="true">
    <img src="/assets/img/faq-bg.jpg" alt="" width="1920" height="960" loading="lazy" decoding="async">
  </div>
  <div class="faq-section__overlay" aria-hidden="true"></div>
  <div class="container">
    <div class="faq-section__content">
      <div aria-hidden="true"></div>{# Left col — image shows through #}
      <div class="faq-section__questions">
        <h2>Frequently Asked Questions</h2>
        {% set faqItems = faqs %}
        {% include "partials/faq.njk" %}
        <p style="margin-top:1.5rem;"><a href="/contact/" class="btn btn-outline-white">Ask Your Question →</a></p>
      </div>
    </div>
  </div>
</section>

{# ── REGIONS WE SERVE ────────────────────────────────────────────────────── #}
<section class="regions" aria-label="Service areas">
  <div class="container">
    <h2>Regions We Serve</h2>
    <div class="regions__grid" role="list">
      {% for region in regions %}
      <div class="regions__city" role="listitem">
        {% if region.slug %}
        <a href="/service-areas/{{ region.slug }}/">{{ region.name }}</a>
        {% else %}
        {{ region.name }}
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ── CTA BAND ────────────────────────────────────────────────────────────── #}
{% include "partials/cta-band.njk" %}

{# ── FAQ SCHEMA ──────────────────────────────────────────────────────────── #}
{% block schema %}
{% set faqItems = faqs %}
{% include "schema/faq.njk" %}
{% endblock %}
