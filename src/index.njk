    <div class="trust-strip__grid">
      <div>
        <h2 class="trust-strip__heading">Why GTA Homeowners Choose Queensway</h2>
        <div class="trust-tiles">
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg></div>
            <span class="trust-tile__text">{{ site.reviewCount }} 5-Star Reviews</span>
          </div>
          <div class="trust-tile fade-in">
            <div class="trust-tile__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <span class="trust-tile__text">Same-Day Emergency Response</span>
