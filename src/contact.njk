---
layout: layouts/base.njk
title: "Contact Queensway Heating and Cooling | Mississauga HVAC"
description: "Contact Queensway Heating and Cooling for furnace repair, AC service, or heat pump installation in Mississauga and the GTA. Same-day emergency service available."
---

<div class="page-hero">
  <div class="container">
    <h1>Contact Us</h1>
    <p>Call us for same-day service, or send us a message and we'll respond within the hour during business hours.</p>
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="content-with-sidebar">

      <div>
        <h2>Send Us a Message</h2>
        <form
          class="form"
          name="contact"
          method="POST"
          action="/api/lead"
          data-form="contact"
          novalidate
          style="max-width:600px"
        >
          <input type="hidden" name="form-name" value="contact">
          <p class="form__honeypot" aria-hidden="true"><label>Leave blank: <input name="bot-field" tabindex="-1" autocomplete="off"></label></p>

          <div class="form__row form__row--half">
            <div>
              <label class="form__label" for="c-name">Name <span class="req">*</span></label>
              <input class="form__input" type="text" id="c-name" name="name" required autocomplete="name">
              <span class="form__error-msg" data-error="name"></span>
            </div>
            <div>
              <label class="form__label" for="c-phone">Phone <span class="req">*</span></label>
              <input class="form__input" type="tel" id="c-phone" name="phone" required autocomplete="tel" inputmode="numeric">
              <span class="form__error-msg" data-error="phone"></span>
            </div>
          </div>

          <div>
            <label class="form__label" for="c-email">Email</label>
            <input class="form__input" type="email" id="c-email" name="email" autocomplete="email">
          </div>

          <div>
            <label class="form__label" for="c-message">How can we help? <span class="req">*</span></label>
            <textarea class="form__textarea" id="c-message" name="message" rows="5" required></textarea>
            <span class="form__error-msg" data-error="message"></span>
          </div>

          <div class="form__submit">
            <button type="submit" class="btn btn-primary btn-lg">Send Message</button>
          </div>
          <div class="form__success" role="alert" aria-live="polite">
            <p><strong>Message sent!</strong> We'll be in touch shortly. For urgent issues call <a href="tel:{{ site.phonePlain }}">{{ site.phone }}</a>.</p>
          </div>
        </form>
      </div>

      <aside aria-label="Contact information">
        <div class="sidebar-card">
          <h3>Phone &amp; Hours</h3>
          <div class="phone-block">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.22 2.18 2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <div>
              <div class="phone-block__number"><a href="tel:{{ site.phonePlain }}">{{ site.phone }}</a></div>
              <div class="phone-block__label">Call or text anytime</div>
            </div>
          </div>
          <p style="font-size:0.875rem;color:var(--color-muted);margin-top:0.5rem;">{{ site.hours }}</p>
          {% if site.emergencyService %}
          <p style="font-size:0.875rem;font-weight:600;color:var(--color-primary);margin:0;">24/7 emergency service available</p>
          {% endif %}
        </div>

        <div class="sidebar-card">
          <h3>Office Address</h3>
          <address style="font-style:normal;font-size:0.875rem;line-height:1.8;">
            {{ site.address.street }}<br>
            {{ site.address.city }}, {{ site.address.province }} {{ site.address.postal }}
          </address>
          <a href="{{ site.address.mapUrl }}" target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="margin-top:1rem;display:inline-flex;">
            Get Directions →
          </a>
        </div>

        <div class="sidebar-card">
          <h3>Email</h3>
          <a href="mailto:{{ site.email }}" style="color:var(--color-primary);word-break:break-all;">{{ site.email }}</a>
        </div>
      </aside>
    </div>

    <div class="map-embed" style="margin-top:3rem;">
      <iframe
        src="https://www.google.com/maps/embed/v1/place?key=YOUR_MAPS_API_KEY&q={{ site.address.street | urlencode }},{{ site.address.city }},{{ site.address.province }}"
        title="Queensway Heating and Cooling office location"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>
