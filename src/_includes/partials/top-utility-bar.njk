<div class="utility-bar" role="complementary" aria-label="Site utilities">
  <div class="container">
    <div class="utility-bar__inner">
      <nav class="utility-bar__nav" aria-label="Secondary navigation">
        <a href="/about/">About</a>
        <a href="/blog/">Blog</a>
        <a href="/service-areas/">Service Areas</a>
        <a href="/reviews/">Reviews</a>
      </nav>
      <div class="utility-bar__cta">
        <div class="reviews-badge" aria-label="{{ site.reviewCount }} 5-star reviews">
          <span class="reviews-badge__stars" aria-hidden="true">
            {% for i in range(0, 5) %}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {% endfor %}
          </span>
          <span class="reviews-badge__count">{{ site.reviewCount }}</span>
          <span>Google Reviews</span>
        </div>
        <a href="tel:{{ site.phonePlain }}" class="utility-phone" aria-label="Call us at {{ site.phone }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.22 2.18 2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          {{ site.phone }}
        </a>
      </div>
    </div>
  </div>
</div>
